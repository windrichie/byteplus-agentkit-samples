# BytePlus Credentials
# Note: The Viking knowledge base SDK currently requires these legacy names
VOLCENGINE_ACCESS_KEY="your_byteplus_access_key_here"
VOLCENGINE_SECRET_KEY="your_byteplus_secret_key_here"

# Cloud Provider (Required for BytePlus endpoints)
CLOUD_PROVIDER=byteplus

# ModelArk Settings
MODEL_AGENT_API_KEY="your_ark_api_key_here"

# MCP Tool (OpenStreetMap via AgentKit Gateway)
MCP_TOOL_URL="https://your-endpoint.volceapi.com/mcp/your-service"
MCP_TOOL_API_KEY="your-mcp-api-key"

# Memory Save Thresholds (Optional, defaults are 10 and 60)
# Set to 1 for immediate saving during testing
MIN_MESSAGES_THRESHOLD=1
MIN_TIME_THRESHOLD=0
